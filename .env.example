# ═══════════════════════════════════════════════════════════════
# ReplyWise Local — v4 config
# Free-cost defaults. Uncomment or edit what you need.
# ═══════════════════════════════════════════════════════════════

PORT=3000
APP_BASE_URL=http://localhost:3000
DATA_DIR=./data
STORE_FILE=./data/replywise.store.json
USER_TIMEZONE=Asia/Karachi

# ── AI Provider ────────────────────────────────────────────────
# local   → zero-cost rule engine (default)
# ollama  → local LLM via Ollama (Llama 3.1 etc.)
# claude  → Anthropic Claude API (best quality, costs tokens)

AI_PROVIDER=local

# Ollama settings (AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ─ OpenAI-compatible endpoint (AI_PROVIDER=openai_compat)
# Works with: LM Studio, llamafile, text-generation-webui, Ollama /v1, OpenAI, etc.
# AI_PROVIDER=openai_compat
# OPENAI_COMPAT_ENDPOINT=http://localhost:1234/v1/chat/completions   # LM Studio default
# OPENAI_COMPAT_MODEL=local-model
# OPENAI_COMPAT_API_KEY=                   # leave blank for local servers
# OPENAI_COMPAT_TEMPERATURE=0.7
# OPENAI_COMPAT_MAX_TOKENS=600
# OPENAI_COMPAT_TIMEOUT_MS=30000
# OPENAI_COMPAT_FORCE=false                # set true to call even for WAIT/NO decisions

# Quick presets (set AI_PROVIDER=openai_compat + one of these = true):
# LM_STUDIO=true      → http://localhost:1234/v1/chat/completions
# LLAMAFILE=true      → http://localhost:8080/v1/chat/completions
# OPENAI=true         → https://api.openai.com/v1/chat/completions (needs API key)

# ─ Claude API settings (AI_PROVIDER=claude)
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-haiku-4-5-20251001
# CLAUDE_FORCE=false          # set true to call Claude even for WAIT/NO decisions

# ── Channels / Agents ─────────────────────────────────────────
# Supported: whatsapp, telegram, wechat
# Each extra agent costs ~250 MB RAM for a headless Chromium.

ENABLED_AGENTS=whatsapp,telegram
# ENABLED_AGENTS=whatsapp,telegram,wechat

BROWSER_HEADLESS=false
SESSION_DIR=./data/sessions

# WeChat-specific
# WECHAT_LOGIN_URL=https://web.wechat.com
# WECHAT_USE_WX2=false      # set true to prefer wx2.qq.com

# ── Media Handling ─────────────────────────────────────────────
# WhatsApp media download (images, audio, files)
# false = metadata-only mode (cheap, recommended default)
# true  = download + classify (uses disk, enables OCR)

WHATSAPP_DOWNLOAD_MEDIA=false
MEDIA_DIR=./data/media

# OCR for images (requires: npm i tesseract.js)
OCR_ENABLED=false
MEDIA_MAX_OCR_MB=2

# ── Browser Automation ────────────────────────────────────────
SCREENSHOT_ON_ERROR=false
ENABLE_LIVE_SCREENSHOTS=false
SCREENSHOT_DIR=./data/screenshots

# Polling & human-like delays (ms)
BRIDGE_POLL_MS=5000
HEALTH_CHECK_INTERVAL=60
TYPING_DELAY_MIN=40
TYPING_DELAY_MAX=130
ACTION_DELAY_MIN=700
ACTION_DELAY_MAX=2400

# ── Smart Autopilot ───────────────────────────────────────────
# Auto-choose: highlights the best option but never sends alone
AUTO_CHOOSE_ENABLED=true

# Auto-send: sends ONLY safe, simple, low-risk replies
# Keep false until tested with sandbox + one whitelisted contact.
AUTO_SEND_ENABLED=false
AUTO_SEND_WHITELIST_ONLY=true
AUTO_SEND_CONFIDENCE_MIN=97
AUTO_SEND_MAX_LENGTH=80
AUTO_SEND_DAILY_LIMIT=20
AUTO_SEND_ALLOW_OPEN_QUESTIONS=false
AUTO_SEND_ALLOW_EMOTIONAL=false

# ── Plugins ───────────────────────────────────────────────────
# Plugin system — built-in plugins can be disabled individually
PLUGIN_WEB_SEARCH=true       # DuckDuckGo instant answers (no API key)
PLUGIN_REMINDER=true         # In-memory reminder stub
# PLUGIN_CALENDAR=false      # Placeholder for future calendar integration

# ── Per-contact reply delay (merged from LLM-for-Whatsapp) ───
# Global default (overridden per-contact from the dashboard)
REPLY_DELAY_MODE=normal          # instant | normal | random
REPLY_DELAY_RANDOM_MIN_MS=1000
REPLY_DELAY_RANDOM_MAX_MS=6000

# ── Safety & Testing ──────────────────────────────────────────
DRY_RUN_SEND=false
MAX_RECENT_MESSAGES=30
PROFILE_REFRESH_MIN_NEW_MESSAGES=25
PROFILE_REFRESH_MAX_MESSAGES=200

# Deprecated alias (kept for backward compat)
ALLOW_AUTOSEND=false

# ── Memory / RAG ──────────────────────────────────────────────
MEMORY_ENABLED=true
MEMORY_BACKEND=tfidf             # tfidf (zero-dep) | ollama (semantic, needs nomic-embed-text)
MEMORY_TOP_K=4                   # snippets to retrieve per message
MEMORY_MIN_SCORE=0.08            # min similarity threshold (0–1)
MEMORY_MAX_SNIPPET_LEN=120       # chars per retrieved snippet
MEMORY_INDEX_WINDOW=200          # last N messages indexed per contact
# MEMORY_EMBED_MODEL=nomic-embed-text   # Ollama embedding model (MEMORY_BACKEND=ollama only)

# ── Agentic Tool-Calling ───────────────────────────────────────
TOOL_CALLING_ENABLED=true
TOOL_CALLING_TIMEOUT_MS=5000     # max ms to wait for all tools before continuing
TOOL_CALLING_MAX=3               # max tools to call per message

# ── Realtime push / Scheduled sends / Feedback learning (v6) ──
# Server-Sent Events for live dashboard updates — replaces 20s reload
# (No config needed; endpoint is /api/events/stream and auto-enabled)

# Scheduler — defers approved replies for later delivery
SCHEDULER_ENABLED=true
SCHEDULER_TICK_MS=30000              # how often to scan the queue (default 30s)
SCHEDULER_MAX_DELAY_HOURS=24         # refuse schedules longer than this

# Feedback learning — no config; reads back chosen_text from feedback_events.
# Tone preferences are computed lazily per contact (60s cache TTL).
# To reset learned preferences for a contact, delete their feedback_events
# rows or reduce LOOKBACK_LIMIT in src/learning/preference-learner.js
