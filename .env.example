# ReplyWise Local — zero messaging API keys, free-cost defaults
PORT=3000
APP_BASE_URL=http://localhost:3000
DATA_DIR=./data
STORE_FILE=./data/replywise.store.json

# Free-cost mode: local rules only by default. Optional: AI_PROVIDER=ollama
AI_PROVIDER=local
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Keep only 1-2 agents. More browsers cost RAM/CPU.
ENABLED_AGENTS=whatsapp,telegram
BROWSER_HEADLESS=false
SESSION_DIR=./data/sessions

# Screenshots are OFF by default. No screenshot/OCR reading loop.
SCREENSHOT_ON_ERROR=false
ENABLE_LIVE_SCREENSHOTS=false
SCREENSHOT_DIR=./data/screenshots
OCR_ENABLED=false

# Slow/cheap polling
BRIDGE_POLL_MS=5000
HEALTH_CHECK_INTERVAL=60
TYPING_DELAY_MIN=40
TYPING_DELAY_MAX=130
ACTION_DELAY_MIN=700
ACTION_DELAY_MAX=2400

# Smart Autopilot
# Auto-choose: system highlights the best option, but does not send by itself.
AUTO_CHOOSE_ENABLED=true

# Auto-send: system can send ONLY safe, simple, low-risk replies.
# Keep false until you test with sandbox + one whitelisted contact.
AUTO_SEND_ENABLED=false
AUTO_SEND_WHITELIST_ONLY=true
AUTO_SEND_CONFIDENCE_MIN=97
AUTO_SEND_MAX_LENGTH=80
AUTO_SEND_DAILY_LIMIT=20
AUTO_SEND_ALLOW_OPEN_QUESTIONS=false
AUTO_SEND_ALLOW_EMOTIONAL=false

# Product safety
# Deprecated name kept for compatibility; use AUTO_SEND_ENABLED above.
ALLOW_AUTOSEND=false
MAX_RECENT_MESSAGES=30
PROFILE_REFRESH_MIN_NEW_MESSAGES=25
PROFILE_REFRESH_MAX_MESSAGES=200

# Optional safety/testing
DRY_RUN_SEND=false
